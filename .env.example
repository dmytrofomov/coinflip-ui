# Copy to .env for local development. All VITE_* vars are baked into the build.

# CoinFlipFactory address used by the app (testnet factory is the default in CI).
# Without it, pass the factory via the ?factory=<address> URL param instead.
VITE_FACTORY_ADDRESS_TESTNET="kQDLbipuUZvCGnFehVhigObfanNyEWrR776vhXy0ouOCaaiM"
# VITE_FACTORY_ADDRESS_MAINNET="EQ..."

# Optional hosted lobby indexer. Empty/unset → the "Лобі" tab disables itself.
# In `npm run dev` the app falls back to http://localhost:8787 automatically.
# VITE_INDEXER_URL="https://your-indexer.example.com"

# Optional Toncenter API keys (raise the ~1 RPS keyless limit).
# TONCENTER_TESTNET_API_KEY="..."
# TONCENTER_MAINNET_API_KEY="..."
